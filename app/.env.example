# Knowledge API — скопируй в app/.env и подставь значения (не коммитить)

# Куда писать SQLite-метаданные и Chroma (по умолчанию: каталог data рядом с app/)
APP_DATA_DIR=

# Опционально (Docker/compose): порт на хосте в сообщении "Open: …" в логе (как в браузере). В docker-compose.yml задаётся APP_EXPOSED_PORT автоматически.
# APP_EXPOSED_PORT=8002

# Если не задан ни один ключ — dev-режим без аутентификации (только для разработки).
# APP_API_KEY — один ключ с полным доступом (admin), legacy.
# Раздельные роли: admin — разделы, ingest, удаление, audit; member — список + чат + export.
APP_API_KEY=
APP_ADMIN_KEY=
APP_MEMBER_KEY=
# Заголовок: X-API-Key: <значение> или Authorization: Bearer <значение>

# Polza (OpenAI-совместимый /chat/completions). По умолчанию внешний вызов LLM выключен.
POLZA_API_KEY=
# Абсолютный URL (http:// или https://). В Docker при ошибке DNS к API — см. app/docs/troubleshooting.md; в docker-compose задан resolv 8.8.8.8.
POLZA_BASE_URL=https://polza.ai/api/v1
# Текстовая модель для RAG-чата (не image-only)
POLZA_CHAT_MODEL=openai/gpt-4o-mini
# Температура /chat/completions (0 = детерминированнее; по умолчанию 0)
POLZA_TEMPERATURE=0
# Необязательно: через запятую; если задано — POLZA_CHAT_MODEL должен входить в список при ALLOW_LLM_EGRESS=true
# POLZA_CHAT_MODEL_ALLOWLIST=openai/gpt-4o-mini,openai/gpt-4o
# Разрешить исходящие запросы к LLM (false — только retrieval + локальный ответ с цитатами)
# ALLOW_LLM_EGRESS=false

# Опционально: лимиты ingest/RAG (см. app/config.py)
# CHUNK_SIZE=800
# CHUNK_OVERLAP=120
# MAX_UPLOAD_MB=10
# RETRIEVAL_TOP_K=8

# Подробные логи и traceback в JSON при X-Debug: 1 (веб-админка). В проде часто: false
# APP_ALLOW_CLIENT_DEBUG=true

# Браузер: CORS. По умолчанию * — не «Failed to fetch» при UI с другого origin. Список: http://localhost:3000,https://app.example.com
# APP_CORS_ORIGINS=*
# Если UI открыт с другого хоста/порта — абсолютный URL API (без слеша в конце), тот же, что в браузере для /v1/...
# APP_PUBLIC_BASE_URL=http://127.0.0.1:8002

# Telegram — отдельные сценарии/уведомления (если используешь)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
