# Сборка без обращения к PyPI: нужен заранее заполненный local-dist/wheels
# (.\scripts\refresh-local-dist.ps1 при рабочей сети). Базовый образ: как в обычном Dockerfile.
FROM python:3.12-slim-bookworm

WORKDIR /app
ENV PYTHONUNBUFFERED=1

COPY local-dist/wheels /wheels
COPY pyproject.toml ./
COPY app ./app
RUN pip install --no-index --find-links /wheels --upgrade pip setuptools wheel \
    && pip install --no-index --find-links /wheels -e .

EXPOSE 8000
CMD ["knowledge-api"]
